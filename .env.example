# Copy this file to .env and fill in your key.
# .env is gitignored — your key will never be committed.
# Get a free key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-paste-your-key-here

# Optional: override the default free model
# Default is openai/gpt-oss-120b:free
# MODEL=openai/gpt-oss-20b:free
# MODEL=openrouter/free

# Optional: override default port (8787)
# PORT=8787
